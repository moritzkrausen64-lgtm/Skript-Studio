skript-studio-app/videos/*.mp4
skript-studio-app/videos/*.mov
skript-studio-app/videos/*.MOV
skript-studio-app/videos/*.avi
skript-studio-app/videos/*.mkv
skript-studio-app/videos/*.webm

# ── Lokale Daten (werden beim Start neu erzeugt) ──────────────
skript-studio-app/data/

# ── Remotion Temp-Bundles ─────────────────────────────────────
skript-studio-app/.remotion/

